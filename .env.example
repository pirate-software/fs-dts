# Port to serve content on
PORT=3000

# Interval to update data in seconds
UPDATE_INTERVAL_SECONDS=86400

# Base URL for the API, used for generating links to images
API_BASE_URL=http://api.psmods.net

# URL for the wiki action api
WIKI_API_URL=https://ferrets.pirate.wiki/w/api.php

# Root URL for wiki pages
WIKI_PAGE_ROOT=https://ferrets.pirate.wiki/

# Set minimum API version to keep
# Lower versions by string comparison will be removed on update
# expects leading "v" i.e. "v2", "v3.1"
API_MIN_VERSION=v1

# Discord webhook URL for update notifications (optional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Discord webhook preamble (inserted before update messages)
# To ping individuals or roles, use <@userID> or <@&roleID>
# Newline will be auto inserted after this preamble
# (optional)
# DISCORD_WEBHOOK_INFO_PREAMBLE="**DTS Update - [INFO] message(s)**"
# DISCORD_WEBHOOK_WARN_PREAMBLE="**DTS Update - [WARN] message(s)** <@254671837219389441> <@204993280780402688>"
# DISCORD_WEBHOOK_ERROR_PREAMBLE="**DTS Update - [ERROR] message(s)** <@254671837219389441> <@204993280780402688>"

# Log levels for console and webhook logging
# Valid levels: debug, info, warn, error
# (optional) - defaults to debug for console and info for webhook
# CONSOLE_LOG_LEVEL=debug
# WEBHOOK_LOG_LEVEL=info

# Cloudflare Access credentials
# (optional) - used on production to prevent cloudflare bot challenges
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=
